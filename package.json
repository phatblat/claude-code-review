{
  "name": "claude-code-review",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generate-then-verify Claude code review GitHub Action: subagent definitions plus a deterministic, tested posting layer.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/main.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/main.js",
    "eval": "tsx evals/scorer.ts"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.41",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.3",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7"
  }
}
